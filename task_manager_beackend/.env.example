# Copy this file to .env and fill in your values. Never commit real credentials.
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=task_manager
DB_POOL_SIZE=5

# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Comma-separated allowed origins, e.g. http://localhost:5173,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# Set to true only during local development
FLASK_DEBUG=false

# Google OAuth Configuration (Optional, Simulator fallback will run if unset)
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
FRONTEND_URL=http://localhost:5173

# SMTP Mail Configuration (Optional, Simulator fallback will run if unset)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_SENDER=your_email@gmail.com

# Brevo API Mailer Configuration (Recommended, bypasses SMTP blocking on cloud platforms)
BREVO_API_KEY=your_brevo_api_key_here
